{
   "compilerOptions":{
      "target":"es6",
      "moduleResolution":"node",
      "module":"commonjs",
      "declaration":false,
      "noLib":false,
      "emitDecoratorMetadata":true,
      "experimentalDecorators":true,
      "sourceMap":true,
      "pretty":true,
      "allowUnreachableCode":true,
      "allowUnusedLabels":true,
      "outDir":"build/src",
      "rootDir": "src"
   },
   "include":[
      "src/**/*.ts"
   ],
   "exclude":[
      "node_modules"
   ],
   "compileOnSave":false
}
